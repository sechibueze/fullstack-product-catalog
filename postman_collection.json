{
  "info": {
    "name": "WFD Product Catalog API",
    "description": "Full API collection for the Product Catalog & Review Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health",
            "description": "Check API, database, and cache health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('token', json.data.token);",
                  "    pm.test('Token saved', function() { pm.expect(json.data.token).to.be.a('string'); });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password\"\n}"
            },
            "description": "Login and auto-save token to collection variable"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/v1/auth/me",
            "description": "Get authenticated user"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/v1/auth/logout",
            "description": "Logout and invalidate token"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/v1/categories?per_page=15&page=1",
              "host": ["{{base_url}}"],
              "path": ["v1", "categories"],
              "query": [
                { "key": "per_page", "value": "15" },
                { "key": "page", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Get Category by Slug",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/v1/categories/electronics",
            "description": "Get single category by slug"
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/v1/categories",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sports & Outdoors\",\n  \"description\": \"Equipment and gear for sports and outdoor activities\"\n}"
            }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/v1/categories/CATEGORY_UUID_HERE",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sports & Outdoors Updated\",\n  \"description\": \"Updated description\"\n}"
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/v1/categories/CATEGORY_UUID_HERE"
          }
        },
        {
          "name": "Create Category - Validation Error",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/v1/categories",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"A\"\n}"
            },
            "description": "Should return 422 with validation errors"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/v1/products?per_page=12&page=1",
              "host": ["{{base_url}}"],
              "path": ["v1", "products"],
              "query": [
                { "key": "per_page", "value": "12" },
                { "key": "page", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "List Products - Filter by Category",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/v1/products?category=electronics",
              "host": ["{{base_url}}"],
              "path": ["v1", "products"],
              "query": [{ "key": "category", "value": "electronics" }]
            }
          }
        },
        {
          "name": "List Products - Search",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/v1/products?search=headphones",
              "host": ["{{base_url}}"],
              "path": ["v1", "products"],
              "query": [{ "key": "search", "value": "headphones" }]
            }
          }
        },
        {
          "name": "Get Product by Slug",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/v1/products/wireless-noise-cancelling-headphones"
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/v1/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category_id\": \"CATEGORY_UUID_HERE\",\n  \"name\": \"Bluetooth Earbuds Pro\",\n  \"description\": \"Premium wireless earbuds with 24h battery and active noise cancellation.\",\n  \"price\": 149.99,\n  \"stock_qty\": 80,\n  \"is_published\": true\n}"
            }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/v1/products/PRODUCT_UUID_HERE",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 129.99,\n  \"stock_qty\": 100\n}"
            }
          }
        },
        {
          "name": "Toggle Published",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/v1/products/PRODUCT_UUID_HERE",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_published\": true\n}"
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/v1/products/PRODUCT_UUID_HERE"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "List All Reviews",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/reviews?per_page=15&page=1",
              "host": ["{{base_url}}"],
              "path": ["v1", "reviews"],
              "query": [
                { "key": "per_page", "value": "15" },
                { "key": "page", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "List Approved Reviews",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/reviews?is_approved=true",
              "host": ["{{base_url}}"],
              "path": ["v1", "reviews"],
              "query": [{ "key": "is_approved", "value": "true" }]
            }
          }
        },
        {
          "name": "List Unapproved Reviews",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/reviews?is_approved=false",
              "host": ["{{base_url}}"],
              "path": ["v1", "reviews"],
              "query": [{ "key": "is_approved", "value": "false" }]
            }
          }
        },
        {
          "name": "Submit Review (Public)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/v1/products/wireless-noise-cancelling-headphones/reviews",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewer_name\": \"John Tester\",\n  \"email\": \"john@tester.com\",\n  \"rating\": 5,\n  \"body\": \"This is an amazing product. Highly recommended to everyone!\"\n}"
            },
            "description": "Public endpoint — no token required. Max 5 requests per minute."
          }
        },
        {
          "name": "Submit Review - Validation Error",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/v1/products/wireless-noise-cancelling-headphones/reviews",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewer_name\": \"J\",\n  \"email\": \"not-an-email\",\n  \"rating\": 10,\n  \"body\": \"Short\"\n}"
            },
            "description": "Should return 422 with multiple validation errors"
          }
        },
        {
          "name": "Approve Review",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/v1/reviews/REVIEW_UUID_HERE/approve"
          }
        },
        {
          "name": "Reject Review",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/v1/reviews/REVIEW_UUID_HERE/reject"
          }
        },
        {
          "name": "Delete Review",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/v1/reviews/REVIEW_UUID_HERE"
          }
        }
      ]
    },
    {
      "name": "Error Scenarios",
      "item": [
        {
          "name": "401 - No Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/v1/categories",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test\"\n}"
            }
          }
        },
        {
          "name": "404 - Product Not Found",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/v1/products/this-does-not-exist"
          }
        },
        {
          "name": "405 - Method Not Allowed",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/v1/auth/login"
          }
        },
        {
          "name": "429 - Rate Limit (submit 6 reviews fast)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/v1/products/wireless-noise-cancelling-headphones/reviews",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reviewer_name\": \"Rate Limiter\",\n  \"email\": \"rate@test.com\",\n  \"rating\": 3,\n  \"body\": \"Testing the rate limiter on this endpoint now.\"\n}"
            },
            "description": "Hit this 6 times quickly — 6th should return 429 Too Many Requests"
          }
        }
      ]
    }
  ]
}
