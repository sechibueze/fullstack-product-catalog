# Production environment variables for docker-compose.prod.yml
# Copy to .env and fill in your Oracle Cloud server details

# Your Oracle Cloud VM public IP or domain
SERVER_IP=

# Frontend URLs (used at build time — baked into the Next.js bundle)
NEXT_PUBLIC_APP_URL=http://SERVER_IP:3000
NEXT_PUBLIC_API_URL=http://SERVER_IP:8000/api/v1
NEXT_PUBLIC_APP_NAME=Product Catalog

# Database — must match backend/.env DB_* values
DB_DATABASE=product_catalog
DB_USERNAME=wfd
DB_PASSWORD=
