# Variables for docker-compose.prod.yml substitution.
# Copy to .env on the server — never commit the real .env.

# EC2 public IP or domain
EC2_HOST=

# Frontend public URLs (baked into the Next.js bundle at build time via GitHub Actions)
NEXT_PUBLIC_APP_URL=http://EC2_HOST:3000
NEXT_PUBLIC_API_URL=http://EC2_HOST:8000/api/v1
NEXT_PUBLIC_APP_NAME=Product Catalog

# Database credentials — must match backend/.env values
DB_DATABASE=product_catalog
DB_USERNAME=wfd
DB_PASSWORD=
